# ===========================================================
# MSGraphClient — Variáveis de Ambiente
# ===========================================================
# Copie este arquivo para .env e preencha com seus valores.
# NUNCA versione o arquivo .env no controle de fontes.
#
# Docs: https://github.com/FSLobao/MSGraphClient/wiki/Configuration
# ===========================================================


# ===========================================================
# OBRIGATÓRIAS (ambos os modos de autenticação)
# ===========================================================

# Azure AD tenant — ID do locatário (obrigatório)
AZURE_TENANT_ID=seu-tenant-id

# ID do aplicativo registrado no Entra ID (obrigatório)
AZURE_CLIENT_ID=seu-client-id

# ID do site SharePoint no formato hostname,site-guid,web-guid (obrigatório)
# Obtenha via: GET https://graph.microsoft.com/v1.0/sites/{hostname}:/{path}
SHAREPOINT_SITE_ID=contoso.sharepoint.com,site-guid,web-guid


# ===========================================================
# OBRIGATÓRIA APENAS PARA client_credentials
# ===========================================================

# Segredo do aplicativo (obrigatório para client_credentials; NÃO usado em delegated)
AZURE_CLIENT_SECRET=seu-client-secret


# ===========================================================
# OPCIONAIS — possuem valores default funcionais
# ===========================================================

# Modo de autenticação (default: client_credentials)
# Valores: client_credentials | delegated
# GRAPH_AUTH_MODE=client_credentials

# Método de login delegado (default: interactive)
# Valores: interactive (popup no browser) | device_code (código no terminal)
# GRAPH_DELEGATED_LOGIN_MODE=interactive

# Redirect URI para fluxo delegado (default: http://localhost)
# Registre http://localhost como "Mobile and desktop applications" no Azure AD
# AZURE_REDIRECT_URI=http://localhost

# Escopos delegados — separados por espaço ou vírgula (default: Sites.Selected)
# Escopos OIDC reservados (openid, profile, offline_access) são adicionados pelo MSAL
# GRAPH_DELEGATED_SCOPES=https://graph.microsoft.com/Sites.Selected

# Tamanho da janela popup de login interativo em WIDTHxHEIGHT (default: 520x680)
# GRAPH_AUTH_POPUP_SIZE=520x680


# ===========================================================
# IDs DE RECURSO — usados por GraphDrive e GraphList
# ===========================================================

# ID da biblioteca de documentos (obtenha via client.site_drives)
SHAREPOINT_DRIVE_ID=seu-drive-id

# ID da lista SharePoint (obtenha via client.site_lists)
SHAREPOINT_LIST_ID=seu-list-id

