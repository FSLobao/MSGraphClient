# Environment variables — copy this to .env and fill in your values
# NEVER commit .env to source control


# ===========================================================
# IDs used to all app registrations in this project — copy from Azure AD portal
# Uncomment and fill in to use this configuration
# ===========================================================

# Azure AD tenant — shared across all app registrations
AZURE_TENANT_ID=your-tenant-id-here

# SharePoint site accessible by this app
SHAREPOINT_SITE_ID=contoso.sharepoint.com,site-guid,web-guid
# Document library drive ID (find via GET /sites/{site-id}/drives)
SHAREPOINT_DRIVE_ID=your-drive-id-here
# SharePoint list ID (find via GET /sites/{site-id}/lists)
SHAREPOINT_LIST_ID=your-list-id-here

# ===========================================================
# Option A — App-only (client credentials)
# Uncomment and fill in to use this configuration
# ===========================================================
#GRAPH_AUTH_MODE=client_credentials

#AZURE_CLIENT_ID=your-read-app-client-id-here
#AZURE_CLIENT_SECRET=your-read-app-client-secret-here

# ===========================================================
# Option B — Delegated (interactive user login)
# Requires "Mobile and desktop applications" redirect URI
# http://localhost registered in Azure AD app registration
# ===========================================================
GRAPH_AUTH_MODE=delegated 

GRAPH_DELEGATED_LOGIN_MODE=interactive # Login method: interactive (browser popup) or device_code (CLI code flow)
AZURE_REDIRECT_URI=http://localhost # Redirect URI — register http://localhost in Azure AD portal

AZURE_CLIENT_ID=your-delegated-app-client-id-here
AZURE_CLIENT_SECRET=your-delegated-app-client-secret-here

# Optional: override default Graph scopes (space or comma separated)
# Reserved OIDC scopes (openid, profile, offline_access) are added by MSAL automatically
# GRAPH_DELEGATED_SCOPES=https://graph.microsoft.com/Sites.Selected

# Optional: popup window size for interactive login (WIDTHxHEIGHT, default 520x680)
# GRAPH_AUTH_POPUP_SIZE=520x720
